# Server
PORT=3040
DRAIN_TIMEOUT=300

# Twilio (Voice)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_PUBLIC_URL=https://your-public-url.example.com

# Speech-to-Text (Deepgram Flux) — transcribes the caller's speech
DEEPGRAM_API_KEY=your_deepgram_api_key
# DEEPGRAM_MODEL=flux-general-en    # default; use nova-2 or nova-3 for non-English caller speech
# Note: Deepgram V2 (Flux) does not accept a language param — language is set via model choice

# LLM
GROQ_API_KEY=your_groq_api_key
LLM_MODEL=groq:openai/gpt-oss-120b
OPENAI_API_KEY=your_openai_api_key

# Text-to-Speech (ElevenLabs)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_flash_v2_5   # default; use eleven_multilingual_v2 for non-English TTS output

# Translation (optional — leave these lines commented out for single-language calls)
# CALLER_LANG = the language the caller speaks (STT input; TTS output when translation enabled)
# CALLEE_LANG = the agent's operating language (LLM thinks and responds in this language)
# Use language names for LLM provider (e.g. Spanish, English, Japanese)
# or ISO 639-1 codes for DeepL (e.g. ES, EN, JA).
#
# Kokoro TTS language selection:
#   KOKORO_LANG / KOKORO_VOICE           = caller's language voice (used when translation active)
#   KOKORO_LANG_CALLEE / KOKORO_VOICE_CALLEE = callee's language voice (no translation / English calls)
#   When translation is NOT active, KOKORO_LANG/KOKORO_VOICE are ignored — callee defaults apply.
#
# Example: caller speaks Chinese, agent operates in English:
#   CALLER_LANG=Chinese               # caller speaks Chinese → STT must be configured for zh
#   CALLEE_LANG=English               # agent (LLM) operates in English
#   TTS_PROVIDER=kokoro
#   KOKORO_LANG=z                     # z = Mandarin — used when CALLER_LANG is active
#   KOKORO_VOICE=zf_xiaobei           # Chinese voice — used when CALLER_LANG is active
#   DEEPGRAM_MODEL=nova-2             # multilingual STT model for Chinese caller speech
#
# CALLER_LANG=Spanish
# CALLEE_LANG=English
# TRANSLATION_PROVIDER=llm
# TRANSLATION_MODEL=llama-3.3-70b-versatile
# DEEPL_API_KEY=your_deepl_api_key
